# OpenRouter API Key (cloud AI mode)
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase
# Get these from your Supabase project dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase Access Token (for API access)
# Get from Supabase Project → Settings → API → Project API Keys (select "service_role" or create custom token)
SUPABASE_ACCESS_TOKEN=sbp_your_access_token_here

# Zogotech Database (for institutional data: enrollment, success rates, demographics)
# Available on-premise only, requires network access to zogotech.siskiyous.edu
ZOGOTECH_DB_PASSWORD=your_password_here
ZOGOTECH_DB_SERVER=zogotech.siskiyous.edu
ZOGOTECH_DB_USER=jtarantino

# AI Mode (cloud or local) — can also be configured via Settings UI
# AI_MODE=local
# LOCAL_AI_URL=http://192.168.1.100:11434/v1
# LOCAL_AI_MODEL=qwen2.5:72b
